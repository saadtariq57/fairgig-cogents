PORT=8003

JWT_SECRET=jwt-secret
JWT_ALGORITHM=HS256

# Set to "true" to force bearer tokens. Left false by default so judges
# can POST the crafted payload from the API contract doc without logging in.
AUTH_REQUIRED=false

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Detection thresholds (override only if you know what you're doing)
ANOMALY_Z_THRESHOLD=2.0
ANOMALY_MOM_DROP_THRESHOLD=0.20
ANOMALY_HOURLY_FLOOR_RATIO=0.60
ANOMALY_MIN_SHIFTS_FOR_ZSCORE=5
