PORT=8001

# Neon — this service owns the "auth" schema
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require&schema=auth

# JWT (must match the value every other service uses to verify tokens)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRY_MIN=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS
FRONTEND_ORIGIN=http://localhost:3000
