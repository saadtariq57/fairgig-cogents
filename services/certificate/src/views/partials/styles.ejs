<style>
  :root {
    --ink: #111;
    --muted: #555;
    --rule: #d0d0d0;
    --accent: #0b5cff;
    --bg: #f4f6f9;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    font-family: "Helvetica Neue", Arial, sans-serif;
    color: var(--ink);
    background: var(--bg);
    -webkit-print-color-adjust: exact;
  }

  .page {
    max-width: 780px;
    margin: 32px auto;
    padding: 48px 56px;
    background: #fff;
    border: 1px solid var(--rule);
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }

  header.masthead {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 16px;
  }

  header.masthead h1 {
    font-size: 22px;
    margin: 0 0 4px 0;
    letter-spacing: 0.5px;
  }

  header.masthead .sub {
    font-size: 12px;
    color: var(--muted);
  }

  header.masthead .brand {
    text-align: right;
    font-size: 11px;
    color: var(--muted);
  }

  .worker-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
    margin: 24px 0 12px;
  }

  .field label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2px;
  }

  .field .value {
    font-size: 14px;
    font-weight: 600;
  }

  .totals {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 24px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 16px 0;
  }

  .totals .card {
    text-align: center;
  }

  .totals .label {
    font-size: 10px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .totals .amount {
    font-size: 20px;
    font-weight: 700;
    margin-top: 4px;
  }

  h2.section {
    font-size: 13px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 24px 0 8px;
  }

  table.breakdown {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  table.breakdown th,
  table.breakdown td {
    padding: 8px 10px;
    border-bottom: 1px solid var(--rule);
    text-align: right;
  }

  table.breakdown th:first-child,
  table.breakdown td:first-child {
    text-align: left;
  }

  table.breakdown thead th {
    font-size: 10px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 2px solid var(--ink);
  }

  table.breakdown tr.totals-row td {
    font-weight: 700;
    border-top: 2px solid var(--ink);
    border-bottom: none;
  }

  .empty-note {
    padding: 16px;
    font-size: 13px;
    color: var(--muted);
    border: 1px dashed var(--rule);
    text-align: center;
  }

  footer.verification {
    margin-top: 32px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
    font-size: 10px;
    color: var(--muted);
    line-height: 1.5;
    word-break: break-all;
  }

  footer.verification .hash {
    font-family: "Menlo", "Courier New", monospace;
    color: var(--ink);
  }

  @page { size: A4; margin: 18mm; }

  @media print {
    body { background: #fff; color: #000; }
    .page {
      margin: 0;
      padding: 0;
      max-width: none;
      border: none;
      box-shadow: none;
    }
    nav, .no-print { display: none !important; }
    header.masthead { border-bottom: 1px solid #000; }
    .totals { border-top: 1px solid #000; border-bottom: 1px solid #000; }
    table.breakdown thead th,
    table.breakdown tr.totals-row td { border-color: #000 !important; }
    .totals .amount, .field .value { color: #000; }
    :root {
      --ink: #000;
      --muted: #333;
      --rule: #999;
      --bg: #fff;
    }
  }
</style>
