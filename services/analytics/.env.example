PORT=8005

# Neon — analytics has READ-ONLY access across the auth/earnings/grievance schemas
# (aggregate queries use schema-qualified names like "earnings"."shifts")
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require

# JWT (must match the value every other service uses to verify tokens)
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret for service-to-service calls
INTERNAL_API_KEY=change-me-too

# Peer service URL (grievance aggregates may read grievance counts live)
GRIEVANCE_SERVICE_URL=http://localhost:8004

# Privacy
K_ANONYMITY_MIN=5

# CORS
FRONTEND_ORIGIN=http://localhost:3000
