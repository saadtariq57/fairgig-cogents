PORT=8002

# Neon — this service owns the "earnings" schema
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require&schema=earnings

# JWT (must match the value every other service uses to verify tokens)
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret for service-to-service calls
INTERNAL_API_KEY=change-me-too

# Uploads (screenshots)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# CORS
FRONTEND_ORIGIN=http://localhost:3000
