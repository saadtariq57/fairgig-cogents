PORT=8004

# Neon — this service owns the "grievance" schema
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require&schema=grievance

# JWT (must match the value every other service uses to verify tokens)
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret for service-to-service calls
INTERNAL_API_KEY=change-me-too

# CORS
FRONTEND_ORIGIN=http://localhost:3000
