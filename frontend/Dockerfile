FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
ARG NEXT_PUBLIC_AUTH_URL
ARG NEXT_PUBLIC_EARNINGS_URL
ARG NEXT_PUBLIC_ANOMALY_URL
ARG NEXT_PUBLIC_GRIEVANCE_URL
ARG NEXT_PUBLIC_ANALYTICS_URL
ARG NEXT_PUBLIC_CERTIFICATE_URL
ENV NEXT_PUBLIC_AUTH_URL=$NEXT_PUBLIC_AUTH_URL \
    NEXT_PUBLIC_EARNINGS_URL=$NEXT_PUBLIC_EARNINGS_URL \
    NEXT_PUBLIC_ANOMALY_URL=$NEXT_PUBLIC_ANOMALY_URL \
    NEXT_PUBLIC_GRIEVANCE_URL=$NEXT_PUBLIC_GRIEVANCE_URL \
    NEXT_PUBLIC_ANALYTICS_URL=$NEXT_PUBLIC_ANALYTICS_URL \
    NEXT_PUBLIC_CERTIFICATE_URL=$NEXT_PUBLIC_CERTIFICATE_URL \
    NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    NEXT_TELEMETRY_DISABLED=1
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3000
CMD ["node", "server.js"]
